        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "let base_url =  pm.collectionVariables.get('BASE_URL')",
                  "pm.collectionVariables.set('XSRF_TOKEN',null)",
                  "pm.sendRequest(`${base_url}sanctum/csrf-cookie`, (err, res) => {",
                  "    if (err) {",
                  "        console.log(err);",
                  "    } else {",
                  "        const { headers } = res",
                  "        console.log(headers)",
                  "        const [xsrf_cookie] = headers.filter(h => h.key == 'Set-Cookie' && h.value.includes('XSRF'))",
                  "        console.log(xsrf_cookie)",
                  "        console.log(xsrf_cookie?.value)",
                  "",
                  "        const [xsrf_cookie_options] = xsrf_cookie?.value.split(';');",
                  "        const xsrf_token = xsrf_cookie_options.replace('%3D', '').replace('XSRF-TOKEN=', '')",
                  "        xsrf_token && pm.collectionVariables.set(\"XSRF-TOKEN\", xsrf_token);",
                  "",
                  "        xsrf_token && console.log(xsrf_token)",
                  "    }",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
